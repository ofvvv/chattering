{
  "name": "chattering",
  "version": "3.5.0",
  "description": "Multi-platform chat viewer",
  "main": "main.cjs",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "express": "^4.18.2",
    "pusher-js": "^8.3.0",
    "socket.io": "^4.6.1",
    "sql.js": "^1.12.0",
    "tiktok-live-connector": "^2.1.1-beta1",
    "tmi.js": "^1.8.5",
    "youtube-chat": "^2.0.2"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.chattering.app",
    "productName": "Chattering",
    "publish": {
      "provider": "github",
      "owner": "ofvvv",
      "repo": "chattering"
    },
    "asar": false,
    "files": [
      "main.cjs",
      "preload.js",
      "resource-monitor.cjs",
      "node_modules/**/*",
      "!node_modules/electron-builder/**/*"
    ],
    "extraResources": [
      {
        "from": "server.js",
        "to": "."
      },
      {
        "from": "public",
        "to": "public"
      },
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "."
      }
    ]
  }
}
